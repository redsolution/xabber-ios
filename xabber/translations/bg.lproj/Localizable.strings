

"web_client__screen_about__preamble_2" = "Можете да намерите повече информация на официалния ни сайт %@";


"web_client__screen_about__preamble_2__link" = "https://www.xabber.com";


"web_client__screen_about__block_1__text" = "Extensible Messaging and Presence Protocol (XMPP) е комуникационен протокол за съобщително-ориентиран мидълуер, базиран на XML (Extensible Markup Language). Той предлага обмен на структурирани, но и същевременно разширими данни в почти реално време между два или повече мрежови агента. Първоначално протоколът е бил наречен Jabber и е бил разработен от Jabber open-source общността през 1999 за поддръжка на обмен на съобщения в почти реално време, информация за присъствие и структуриране на списък с контакти.";


"web_client__screen_about__block_2__header" = "XMPP Extension Protocols";


"web_client__screen_about__block_2__text" = "XMPP може да се разширява лесно чрез XEP (XMPP Extension Protocol) добавки. %@ поддържа няколко популярни XEP, които са в основата на страхотното чат преживяване на нашите потребители.";


"web_client__screen_about__block_3__header" = "Разработчици";


"client_developer_company_name" = "Redsolution";


"web_client__screen_about__block_3__text_1" = "%1$@ е първоначано разработен от %2$@ - международна софтуерна компания, базирана в Естония. Оттогава много хора са се присъединили към %3$@ като разработчици, тестери и преводачи.";


"web_client__screen_about__block_3__text_3" = "Последвайте ни в Twitter и Github.";


"web_client__screen_about__block_4__header" = "Преводачи";


"web_client__screen_about__block_4__text_1" = "%@ е преведен на няколко езика благодарение на много прекрасни хора от цял свят. Създали сме специална страница на нашия уебсайт, за да покажем признание към техните усилия.";


"web_client__screen_about__block_4__text_2" = "Можете да се присъедините към тях и да ни помогнете да подобрим качеството на преводите, като допринесете с вашия превод на %@";


"web_client__screen_about__block_4__text_2__link__text" = "%@ проект";


