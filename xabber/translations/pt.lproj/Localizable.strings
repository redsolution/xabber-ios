

"web_client__screen_about__preamble_1" = "%1$@ é um mensageiro XMPP de código aberto para plataformas Android, iOS e Web. É construída em torno de padrões abertos, interoperabilidade, design e ótima experiência de usuário. Versões de %2$@ para cada plataforma são criadas para proporcionar uma experiência de bate-papo contínua entre elas.";


"web_client__screen_about__preamble_2" = "Você encontrará mais informações em nosso site oficial %@";


"web_client__screen_about__preamble_2__link" = "https://www.xabber.com";


"web_client__screen_about__block_1__header" = "Protocolo XMPP";


"web_client__screen_about__block_1__text" = "Extensible Messaging and Presence Protocol (XMPP) é um protocolo de comunicação para um middleware orientado a mensagens baseado em XML (Extensible Markup Language). Permite o intercâmbio quase em tempo real de dados estruturados, mas extensíveis, entre duas ou mais entidades de rede. O protocolo foi originalmente nomeado como Jabber e foi desenvolvido pela comunidade de código aberto Jabber em 1999 para mensagens instantâneas quase em tempo real (IM), informação de presença e manutenção da lista de contatos.";


"web_client__screen_about__block_2__header" = "Protocolos de extensão XMPP";


"web_client__screen_about__block_2__text" = "XMPP é altamente extensível, por meio de extensões conhecidas como XEPs (protocolo de extensão XMPP). %@ suporta uma série de XEPs populares que são essenciais para fornecer uma ótima experiência de bate-papo para nossos usuários.";


"web_client__screen_about__block_3__header" = "Desenvolvedores";


"client_developer_company_name" = "Redsolution";


"web_client__screen_about__block_3__text_1" = "%1$@ foi originalmente desenvolvida por %2$@ — uma empresa internacional de software e serviços atualmente localizada na Estônia. Desde então, um número de indivíduos ingressou em %3$@ como desenvolvedores, testadores e tradutores.";


"web_client__screen_about__block_3__text_2" = "Nosso objetivo é criar um ambiente estável, confiável ecossistema interoperável e amigo do utilizador para mensagens instantâneas que não dependem de serviços de propriedade e silos de dados. Saudamos qualquer pessoa que acredite em padrões abertos e intercâmbios de informações gratuitas para participar do progresso de %@.";


"web_client__screen_about__block_3__text_3" = "Siga-nos no Twitter e no Github.";


"web_client__screen_about__block_4__header" = "Tradutores";


"web_client__screen_about__block_4__text_1" = "%@ está disponível em vários idiomas graças a muitas pessoas de todo o mundo. Criámos uma página especial no nosso sítio Web para reconhecer os seus esforços.";


"web_client__screen_about__block_4__text_2" = "Você pode se juntar a eles e nos ajudar a melhorar a qualidade da tradução, contribuindo com suas traduções para %@";


"web_client__screen_about__block_4__text_2__link__text" = "Projeto de %@";


"web_client__screen_about__block_5__header" = "Licença";


"web_client__screen_about__block_5__text_1__link__text" = "GitHub";


"web_client__screen_about__block_5__text_1" = "O código-fonte %1$@ está licenciado sob a licença GNU AGPL v.3 e está disponível em %2$@";


"web_client__screen_about__block_5__text_2" = "Imagens gráficas são licenciadas sob a licença Creative Commons Attribution Share-Alike (CC BY-SA).";


"web_client__screen_about__block_5__text_3" = "%1$@ & %2$@ logotipo são propriedade de %3$@";


